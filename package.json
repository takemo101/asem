{
  "name": "asem",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local agent session manager (monorepo root)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
