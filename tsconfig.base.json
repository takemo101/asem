{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ESNext"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@asem/core": ["packages/core/src/index.ts"],
      "@asem/integrations": ["packages/integrations/src/index.ts"],
      "@asem/runtime": ["packages/runtime/src/index.ts"],
      "@asem/profiles": ["packages/profiles/src/index.ts"],
      "@asem/store": ["packages/store/src/index.ts"],
      "@asem/ops": ["packages/ops/src/index.ts"],
      "@asem/cli": ["packages/cli/src/index.ts"],
      "@asem/mcp": ["packages/mcp/src/index.ts"],
      "@asem/tui": ["packages/tui/src/index.ts"],
      "@asem/tui/opentui": ["packages/tui/src/opentui/index.ts"]
    }
  }
}
